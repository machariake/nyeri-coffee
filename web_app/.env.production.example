# Production Environment Variables for Web App
# Copy this file to .env.production and update the values

# Backend API URL (Update with your Render backend URL)
REACT_APP_API_URL=https://cncms-backend.onrender.com/api

# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Application Settings
REACT_APP_ENV=production
